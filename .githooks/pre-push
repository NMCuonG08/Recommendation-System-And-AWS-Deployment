#!/usr/bin/env bash
# Pre-push secret guard — last line of defense before secrets leave the machine.
# Self-contained: only needs git + grep.
set -uo pipefail

secret_patterns='AKIA[0-9A-Z]{16}|aws_secret_access_key["'\'' ]*[:=]["'\'' ]*[A-Za-z0-9/+=]{30,}|KAGGLE_KEY["'\'' ]*[:=]["'\'' ]*[A-Za-z0-9_]{20,}|postgresql?://[^:]+:[^@]{6,}@[^"]+|PG_PASSWORD["'\'' ]*[:=]["'\'' ]*[A-Za-z0-9]{6,}|sk-[A-Za-z0-9]{20,}|-----BEGIN (RSA |EC |OPENSSH )?PRIVATE KEY-----'
allowlist='admin|Password1234|postgres:postgres@localhost|CHANGE_ME|REPLACE_ME|your-|example|changeme|XXXX'

blocked=0
while read -r local_ref local_sha remote_ref remote_sha; do
  if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
    range="$local_sha"
  else
    range="$local_sha...$remote_sha"
  fi
  files=$(git diff --name-only "$range" 2>/dev/null || echo "")
  [ -z "$files" ] && continue
  while IFS= read -r f; do
    [ -f "$f" ] || continue
    # Collect matches, drop allowlisted lines.
    hits=$(grep -nE "$secret_patterns" "$f" 2>/dev/null | while IFS= read -r line; do
      echo "$line" | grep -qiE "\$\{|$allowlist" && continue
      echo "$line"
    done || true)
    if [ -n "$hits" ]; then
      echo "pre-push BLOCKED: secret in $f:" >&2
      echo "$hits" >&2
      blocked=1
    fi
  done <<< "$files"
done

if [ "$blocked" -ne 0 ]; then
  exit 1
fi
echo "pre-push: clean."
exit 0
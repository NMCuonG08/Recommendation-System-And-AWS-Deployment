# Copy this file to .env and fill in real values.
# .env is gitignored; .env.example is tracked as a template.
# See docs/README.md for how to get AWS credentials and create RDS + S3.

# ===== Kaggle credentials =====
# Create at https://www.kaggle.com/settings/account -> Create New Token
# Downloads a kaggle.json with these two fields.
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# ===== Dataset to download (kagglehub.dataset_download) =====
KAGGLE_DATASET=shubhammehta21/movie-lens-small-latest-dataset

# ===== Project config =====
RANDOM_SEED=42
# Where prepared parquet files are written (relative to notebooks/)
NOTEBOOK_PERSIST_DIR=data/001-prepare-dataset

# ===== 002 upload: LOCAL vs AWS =====
# true  = use local Docker services (Postgres + MinIO)  -> see docker-compose.yml
# false = use real AWS (RDS Postgres + S3)              -> see docs/README.md
DATA_UPLOAD_USE_LOCAL=true

# ===== Object storage (S3 / MinIO) =====
# AWS creds: IAM -> Users -> Security credentials (for S3). Leave empty for local MinIO.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
S3_BUCKET=recsys-ops
# MinIO local endpoint. Leave EMPTY to use real AWS S3.
S3_ENDPOINT=http://localhost:9000

# ===== OLTP database (Postgres / RDS) =====
# Local Docker defaults: postgres/postgres @ localhost:5435/raw_data
# AWS RDS: fill PG_HOST with the RDS endpoint, PG_USER/PG_PASSWORD from RDS setup.
PG_USER=
PG_PASSWORD=
PG_HOST=localhost
PG_PORT=5435
PG_DB=raw_data
PG_SCHEMA=public
PG_TABLE=movie_ratings

# ===== Feast Feature Store registry (AWS real) =====
# Second database on the SAME RDS instance, created manually once:
#   CREATE DATABASE registry_feature_store;
# Feast stores its feature-view registry here (registry_type: sql).
REGISTRY_DB=registry_feature_store
# SQLAlchemy-style URI consumed by feature_store.yaml as ${POSTGRES_URI_REGISTRY}.
# URL-encode the password if it contains special chars (@ : / # etc.).
# Build from the RDS master creds above:
#   postgresql://<PG_USER>:<urlencoded PG_PASSWORD>@<PG_HOST>:<PG_PORT>/<REGISTRY_DB>
POSTGRES_URI_REGISTRY=postgresql://postgres:postgres@localhost:5435/registry_feature_store

# ===== DynamoDB (Feast online store, AWS real) =====
# No extra keys — DynamoDB reuses AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY /
# AWS_DEFAULT_REGION above. The IAM user just needs dynamodb:* permission
# (see docs/README.md "Path C"). Feast creates the tables on `feast apply`.

# ===== 007 MLflow tracking (Ray Tune + final training) =====
# Local-pro: MLflow server runs via `docker compose up -d` on http://localhost:5000,
# backend store = a `mlflow` database on the same Postgres, artifact store = MinIO
# (S3-compatible) under s3://recsys-ops/mlflow/.
# AWS real: run an MLflow server on EC2/ECS with an RDS Postgres backend + S3
# artifact root, then point MLFLOW_TRACKING_URI at it and EMPTY MLFLOW_S3_ENDPOINT_URL.
# No new AWS API key — MLflow reuses AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY +
# RDS (PG_*) + S3 (S3_BUCKET) from Path B. See docs/README.md "Path D".
MLFLOW_TRACKING_URI=http://localhost:5000
# Postgres backend store for MLflow (a dedicated `mlflow` DB on the same instance).
# Local: localhost:5435. AWS: RDS endpoint + a `mlflow` DB you create once.
MLFLOW_BACKEND_STORE=postgresql://postgres:postgres@localhost:5435/mlflow
# Artifact root — local uses the MinIO bucket; AWS uses the real S3 bucket.
MLFLOW_ARTIFACT_ROOT=s3://recsys-ops/mlflow
# MinIO endpoint for the boto3 client MLflow uses to upload artifacts.
# Local: http://localhost:9000. AWS (real S3): LEAVE EMPTY.
MLFLOW_S3_ENDPOINT_URL=http://localhost:9000
# Credentials MLflow's boto3 client uses for the artifact store.
# Local MinIO: admin / Password1234 (match docker-compose.minio).
# AWS real S3: set these = AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY.
MLFLOW_AWS_ACCESS_KEY_ID=admin
MLFLOW_AWS_SECRET_ACCESS_KEY=Password1234

# ===== 007 Ray (distributed HP search + training) =====
# Local single-machine: `local` (ray.init starts an in-process cluster).
# EKS KubeRay, running inside the head pod: `auto` (joins the local cluster).
# EKS KubeRay, submitting from outside the cluster: ray://raycluster-kuberay-head-svc:10001
RAY_ADDRESS=local

# ===== EKS (Path D.2 real — set when running on the EKS Ray head pod) =====
# Full step-by-step: docs/eks-deploy.md. In-cluster MLflow stack (Postgres + MinIO)
# deployed via infra/mlflow-stack helm; Ray via infra/ray-cluster helm + KubeRay operator.
# These in-cluster service DNS names only resolve from inside the cluster.
MLFLOW_TRACKING_URI_EKS=http://mlflow-tracking-service.mlflow.svc.cluster.local:5000
MLFLOW_S3_ENDPOINT_URL_EKS=http://minio-service.mlflow.svc.cluster.local:9000
MLFLOW_AWS_ACCESS_KEY_ID_EKS=admin
MLFLOW_AWS_SECRET_ACCESS_KEY_EKS=Password1234
# Region the EKS cluster lives in (match infra/terraform_eks/variables.tf).
AWS_DEFAULT_REGION_EKS=ap-southeast-1
# Your Docker Hub username — used by infra/scripts/build_push.sh to tag/push
# <DOCKER_USER>/recsys-mlflow:v1 and <DOCKER_USER>/recsys-ray:v1.
DOCKER_USER=your-docker-hub-username
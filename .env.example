# Copy this file to .env and fill in real values.
# .env is gitignored; .env.example is tracked as a template.
# See docs/README.md for how to get AWS credentials and create RDS + S3.

# ===== Kaggle credentials =====
# Create at https://www.kaggle.com/settings/account -> Create New Token
# Downloads a kaggle.json with these two fields.
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# ===== Dataset to download (kagglehub.dataset_download) =====
KAGGLE_DATASET=shubhammehta21/movie-lens-small-latest-dataset

# ===== Project config =====
RANDOM_SEED=42
# Where prepared parquet files are written (relative to notebooks/)
NOTEBOOK_PERSIST_DIR=data/001-prepare-dataset

# ===== 002 upload: LOCAL vs AWS =====
# true  = use local Docker services (Postgres + MinIO)  -> see docker-compose.yml
# false = use real AWS (RDS Postgres + S3)              -> see docs/README.md
DATA_UPLOAD_USE_LOCAL=true

# ===== Object storage (S3 / MinIO) =====
# AWS creds: IAM -> Users -> Security credentials (for S3). Leave empty for local MinIO.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
S3_BUCKET=recsys-ops
# MinIO local endpoint. Leave EMPTY to use real AWS S3.
S3_ENDPOINT=http://localhost:9000

# ===== OLTP database (Postgres / RDS) =====
# Local Docker defaults: postgres/postgres @ localhost:5435/raw_data
# AWS RDS: fill PG_HOST with the RDS endpoint, PG_USER/PG_PASSWORD from RDS setup.
PG_USER=
PG_PASSWORD=
PG_HOST=localhost
PG_PORT=5435
PG_DB=raw_data
PG_SCHEMA=public
PG_TABLE=movie_ratings